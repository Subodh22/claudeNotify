# Run `node generate-keys.js` to produce these values
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Random secret to protect /api/notify — generate-keys.js prints one
NOTIFY_SECRET=

# From https://console.upstash.com/qstash — free account, no credit card
QSTASH_TOKEN=

# Your deployed Vercel URL (no trailing slash)
APP_URL=https://your-app.vercel.app
